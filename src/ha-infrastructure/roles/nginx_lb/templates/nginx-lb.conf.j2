{% if vts_module_check is defined and vts_module_check.rc == 0 %}
vts_status_zone;
vts_status_filter_by_host on;
{% endif %}

{% for port in nginx.http_ports %}
    upstream app_backend_{{ port }} {
    {% for host in groups['app_nodes'] %}
        {% set hostvars_data = hostvars[host] %}
        server {{ hostvars_data.ansible_host }}:{{ port }} max_fails=3 fail_timeout=30s;
    {% endfor %}
    }

    server {
    listen {{ port }};
    server_name _;

    location / {
    proxy_pass http://app_backend_{{ port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Health check endpoint for load balancer itself
    location /nginx-health {
    access_log off;
    return 200 "healthy\n";
    add_header Content-Type text/plain;
    }
    }
{% endfor %}

# Monitoring and Status server
server {
listen 8888;
server_name _;

location /nginx_status {
    stub_status on;
    access_log off;
    allow 127.0.0.1;
    {% for host in groups['monitoring'] %}
    allow {{ hostvars[host].ansible_host }};
    {% endfor %}
    deny all;
}

location /status {
    {% if vts_module_check is defined and vts_module_check.rc == 0 %}
    vts_status on;
    vts_status_format html;
    {% else %}
    stub_status on;
    {% endif %}
    allow 127.0.0.1;
    {% for host in groups['monitoring'] %}
    allow {{ hostvars[host].ansible_host }};
    {% endfor %}
    deny all;
}
}