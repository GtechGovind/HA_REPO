apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: "http://localhost:{{ monitoring.prometheus_port }}"
    isDefault: true
    editable: false

  - name: Loki
    type: loki
    access: proxy
    url: "http://localhost:{{ monitoring.loki_port }}"
    editable: false
