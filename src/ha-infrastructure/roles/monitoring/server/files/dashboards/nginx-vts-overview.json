{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 10,
      "options": {
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_vts_server_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "title": "Total Request Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_vts_server_requests_total{code=\"5xx\"}[5m])) / sum(rate(nginx_vts_server_requests_total[5m])) * 100",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 12,
      "options": {
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "avg(nginx_vts_upstream_response_time_seconds)",
          "refId": "A"
        }
      ],
      "title": "Avg Response Time",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_vts_server_requests_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Instance",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 13,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_vts_upstream_requests_total[5m])) by (upstream)",
          "legendFormat": "{{ upstream }}",
          "refId": "A"
        }
      ],
      "title": "Upstream Traffic Distribution",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "id": 100,
      "targets": [
        {
          "expr": "{job=\"varlogs\", host=~\"app.*\"} | json | line_format \"{{.remote_addr}} - {{.request}} {{.status}} {{.body_bytes_sent}}\"",
          "refId": "A"
        }
      ],
      "title": "Application Access Logs",
      "type": "logs"
    }
  ],
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["nginx", "ha", "vts"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Nginx Global Traffic Control",
  "uid": "nginx-traffic-control",
  "version": 1
}
