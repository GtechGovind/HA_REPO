{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 0, "text": "STANDBY" },
                "1": { "color": "green", "index": 1, "text": "PRIMARY" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "id": 10,
      "options": {
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "text": {},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "pg_is_primary",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Node Roles (Primary/Standby)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "id": 11,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "sum(pg_static) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Active DB Connections",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[5m])",
          "legendFormat": "{{ datname }} - Commits",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback[5m])",
          "legendFormat": "{{ datname }} - Rollbacks",
          "refId": "B"
        }
      ],
      "title": "Transaction Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 12,
      "targets": [
        {
          "expr": "pg_database_size_bytes",
          "legendFormat": "{{ datname }}",
          "refId": "A"
        }
      ],
      "title": "Database Size",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 13,
      "targets": [
        {
          "expr": "pg_replication_lag_seconds",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Replication Lag (Seconds)",
      "type": "timeseries"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "id": 100,
      "targets": [
        {
          "expr": "{job=\"varlogs\", host=~\"db.*\"} |= \"ERROR\" or |= \"FATAL\"",
          "refId": "A"
        }
      ],
      "title": "Database Error Logs",
      "type": "logs"
    }
  ],
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["postgresql", "ha", "repmgr"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "PostgreSQL HA Cluster Control",
  "uid": "postgresql-ha-control",
  "version": 1
}
