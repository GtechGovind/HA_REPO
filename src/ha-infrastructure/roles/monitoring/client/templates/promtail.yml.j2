server:
  http_listen_port: {{ monitoring.promtail_port }}
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ groups['monitoring'][0] }}:{{ monitoring.loki_port }}/loki/api/v1/push

scrape_configs:
  - job_name: system
    static_configs:
    - targets:
        - localhost
      labels:
        job: varlogs
        __path__: /var/log/*log
        host: {{ inventory_hostname }}
