# ==============================================================================
# Repmgr Configuration Template
# ==============================================================================
node_id={{ postgresql_id }}
node_name='{{ inventory_hostname }}'
conninfo='host={{ ansible_host }} user=repmgr dbname=repmgr connect_timeout=2 password={{ vault_repmgr_password }}'
data_directory='{{ postgresql.data_dir }}'

# Use replication slots
use_replication_slots=yes

# Failover settings
failover=automatic
promote_command='repmgr standby promote -f /etc/postgresql/{{ postgresql.version }}/main/repmgr.conf --log-to-file'
follow_command='repmgr standby follow -f /etc/postgresql/{{ postgresql.version }}/main/repmgr.conf --log-to-file --upstream-node-id=%n'

# Monitoring
monitoring_history=yes
monitor_interval_secs=2

# Logging
log_file='/var/log/postgresql/repmgr.log'
log_level=INFO

# Failover settings (Faster for industry-standard)
reconnect_attempts=3
reconnect_interval=5
primary_visibility_timeout=10
standby_disconnect_on_failover=yes

# Command and script settings
pg_bindir='/usr/lib/postgresql/{{ postgresql.version }}/bin'
event_notification_command='/bin/bash /opt/ha-infrastructure/scripts/failover-notify.sh %e'

# Service management commands (PostgreSQL cluster-specific)
service_start_command='/usr/bin/pg_ctlcluster {{ postgresql.version }} main start'
service_stop_command='/usr/bin/pg_ctlcluster {{ postgresql.version }} main stop'
service_restart_command='/usr/bin/pg_ctlcluster {{ postgresql.version }} main restart'
service_reload_command='/usr/bin/pg_ctlcluster {{ postgresql.version }} main reload'
